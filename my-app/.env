# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Stock Management"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────
# POSTGRESQL DATABASE
# ─────────────────────────────────────────────

# Option 1 — Single connection string (recommended)
DATABASE_URL=postgresql://postgres:postgresql@localhost:5432/stock_management

# Option 2 — Individual fields (if using `pg` package directly)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stock_management
DB_USER=postgres
DB_PASSWORD=postgresql

# ─────────────────────────────────────────────
# API (Backend on Onrender)
# ─────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api
# Production:
# NEXT_PUBLIC_API_BASE_URL=https://your-backend.onrender.com/api/v1

# ─────────────────────────────────────────────
# AUTHENTICATION (NextAuth.js)
# ─────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_super_secret_key_here

# ─────────────────────────────────────────────
# JWT (if using custom auth)
# ─────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# RAZORPAY
# ─────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ─────────────────────────────────────────────
# CLOUDINARY (product image uploads)
# ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# ─────────────────────────────────────────────
# EMAIL
# ─────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password